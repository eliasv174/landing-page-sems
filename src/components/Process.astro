---
// src/components/Process.astro

const steps = [
  {
    number: '01',
    title: 'Diagnóstico',
    description: 'Analizamos tu empresa, procesos actuales y necesidades tecnológicas para entender el punto de partida y oportunidades de mejora.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>`,
  },
  {
    number: '02',
    title: 'Propuesta',
    description: 'Diseñamos una solución personalizada con alcance claro, tecnologías adecuadas, cronograma y presupuesto transparente.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>`,
  },
  {
    number: '03',
    title: 'Implementación',
    description: 'Ejecutamos el proyecto con metodologías ágiles, comunicación constante y entregas parciales para que veas el avance en tiempo real.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>`,
  },
  {
    number: '04',
    title: 'Soporte',
    description: 'Acompañamos a tu equipo post-entrega con capacitación, mantenimiento y soporte técnico para garantizar el éxito a largo plazo.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 2.18h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 9.91a16 16 0 0 0 6.07 6.07l1.79-1.79a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>`,
  },
];
---

<section id="proceso" class="section process-section" aria-labelledby="proceso-title">
  <div class="container">
    <div class="section-header reveal">
      <span class="section-eyebrow">Cómo trabajamos</span>
      <h2 class="section-title" id="proceso-title">
        Nuestro <span class="accent">Proceso</span>
      </h2>
      <div class="divider"></div>
      <p class="section-subtitle">
        Un método probado que garantiza resultados. Transparencia y colaboración en cada etapa.
      </p>
    </div>

    <!-- Process Steps -->
    <div class="process-track" role="list">
      {steps.map((step, i) => (
        <div
          class={`process-step reveal delay-${i + 1}`}
          role="listitem"
          id={`step-${i + 1}`}
        >
          <!-- Connector line (not last) -->
          {i < steps.length - 1 && (
            <div class="step-connector" aria-hidden="true"></div>
          )}

          <div class="step-inner">
            <div class="step-number-wrap" aria-hidden="true">
              <span class="step-number">{step.number}</span>
              <div class="step-icon" set:html={step.icon}></div>
            </div>

            <div class="step-content">
              <h3 class="step-title">{step.title}</h3>
              <p class="step-desc">{step.description}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .process-section {
    background: linear-gradient(180deg, var(--color-bg-primary) 0%, var(--color-bg-secondary) 50%, var(--color-bg-primary) 100%);
  }

  .process-track {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-4);
    position: relative;
  }

  .process-step {
    position: relative;
    display: flex;
    flex-direction: column;
  }

  /* Connector line */
  .step-connector {
    position: absolute;
    top: 44px;
    right: calc(-50% + 28px);
    width: calc(100% - 56px);
    height: 2px;
    background: linear-gradient(90deg, var(--color-accent-cyan), var(--color-accent-violet));
    opacity: 0.3;
    z-index: 0;
  }

  .step-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--space-6);
  }

  /* Number + Icon */
  .step-number-wrap {
    position: relative;
    width: 88px;
    height: 88px;
    border-radius: 50%;
    background: var(--color-bg-card);
    border: 2px solid var(--color-border);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all var(--transition-base);
    z-index: 1;
    flex-shrink: 0;
  }

  .process-step:hover .step-number-wrap {
    border-color: var(--color-accent-cyan);
    box-shadow: var(--shadow-glow);
  }

  .step-number {
    position: absolute;
    top: -12px;
    right: -8px;
    font-family: var(--font-display);
    font-size: var(--text-xs);
    font-weight: 700;
    color: var(--color-accent-cyan);
    background: var(--color-bg-primary);
    padding: 0.15rem 0.4rem;
    border-radius: var(--radius-full);
    border: 1px solid var(--color-border);
  }

  .step-icon {
    color: var(--color-accent-cyan);
    transition: color var(--transition-base), transform var(--transition-base);
  }

  .process-step:hover .step-icon {
    color: white;
    transform: scale(1.1);
  }

  .step-content { display: flex; flex-direction: column; gap: var(--space-2); }

  .step-title {
    font-size: var(--text-lg);
    font-weight: 700;
    color: var(--color-text-primary);
  }

  .step-desc {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    line-height: 1.6;
  }

  @media (max-width: 900px) {
    .process-track {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-8);
    }
    .step-connector { display: none; }
  }

  @media (max-width: 540px) {
    .process-track { grid-template-columns: 1fr; }
    .step-inner { flex-direction: row; text-align: left; }
    .step-number-wrap { flex-shrink: 0; }
  }
</style>
