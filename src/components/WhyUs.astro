---
// src/components/WhyUs.astro

const reasons = [
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`,
    title: 'Equipo Especializado',
    description: 'Profesionales certificados con experiencia real en proyectos tecnológicos empresariales en Guatemala y Latinoamérica.',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>`,
    title: 'Calidad Garantizada',
    description: 'Entregamos soluciones con estándares de calidad international y mejores prácticas de la industria. Tu satisfacción es nuestra prioridad.',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="4" width="22" height="16" rx="2" ry="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>`,
    title: 'Precios Accesibles',
    description: 'Soluciones de alto impacto con presupuestos adaptados a la realidad de las PYMEs guatemaltecas. Sin costos ocultos.',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>`,
    title: 'Enfoque Local',
    description: 'Entendemos el contexto empresarial guatemalteco: regulaciones, cultura de negocio y necesidades específicas del mercado local.',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>`,
    title: 'Resultados Medibles',
    description: 'Definimos KPIs claros desde el inicio. Cada proyecto incluye métricas de éxito para que puedas medir el ROI de tu inversión tecnológica.',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`,
    title: 'Soporte Continuo',
    description: 'No desaparecemos después de entregar. Ofrecemos soporte técnico, mantenimiento y acompañamiento post-implementación.',
  },
];
---

<section id="por-que" class="section" aria-labelledby="porque-title">
  <div class="container">
    <div class="section-header reveal">
      <span class="section-eyebrow">Nuestras ventajas</span>
      <h2 class="section-title" id="porque-title">
        ¿Por qué elegir <span class="accent">SEMS?</span>
      </h2>
      <div class="divider"></div>
      <p class="section-subtitle">
        Con SEMS tienes un socio tecnológico comprometido con el crecimiento real de tu empresa.
      </p>
    </div>

    <div class="why-grid">
      {reasons.map((reason, i) => (
        <div
          class={`why-item reveal delay-${(i % 3) + 1}`}
          id={`why-${i + 1}`}
        >
          <div class="why-icon" aria-hidden="true" set:html={reason.icon}></div>
          <div class="why-content">
            <h3 class="why-title">{reason.title}</h3>
            <p class="why-desc">{reason.description}</p>
          </div>
        </div>
      ))}
    </div>

    <!-- Trust Bar -->
    <div class="trust-bar reveal">
      <p class="trust-text">Tecnologías y ecosistemas con los que trabajamos</p>
      <div class="tech-stack" role="list" aria-label="Stack tecnológico">
        {['React', 'Node.js', 'Python', 'PostgreSQL', 'AWS', 'Docker', 'Next.js', 'TypeScript'].map(tech => (
          <span class="tech-tag" role="listitem">{tech}</span>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .why-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-6);
    margin-bottom: var(--space-16);
  }

  .why-item {
    display: flex;
    align-items: flex-start;
    gap: var(--space-4);
    padding: var(--space-6);
    background: var(--gradient-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    transition: all var(--transition-base);
  }

  .why-item:hover {
    border-color: var(--color-border-hover);
    transform: translateY(-3px);
    box-shadow: var(--shadow-glow);
  }

  .why-icon {
    width: 44px;
    height: 44px;
    border-radius: var(--radius-md);
    background: rgba(0,212,255,0.08);
    border: 1px solid var(--color-border);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-accent-cyan);
    flex-shrink: 0;
    transition: all var(--transition-base);
  }

  .why-item:hover .why-icon {
    background: rgba(0,212,255,0.15);
    border-color: var(--color-accent-cyan);
  }

  .why-content { display: flex; flex-direction: column; gap: var(--space-2); }

  .why-title {
    font-size: var(--text-base);
    font-weight: 700;
    color: var(--color-text-primary);
  }

  .why-desc {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    line-height: 1.6;
  }

  /* Trust Bar */
  .trust-bar {
    text-align: center;
    padding: var(--space-8);
    border-radius: var(--radius-xl);
    background: rgba(255,255,255,0.02);
    border: 1px solid var(--color-border);
  }

  .trust-text {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin-bottom: var(--space-4);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-weight: 600;
  }

  .tech-stack {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-3);
  }

  .tech-tag {
    font-family: var(--font-display);
    font-size: var(--text-sm);
    font-weight: 600;
    padding: 0.4rem 1rem;
    border-radius: var(--radius-full);
    background: rgba(0,212,255,0.06);
    border: 1px solid var(--color-border);
    color: var(--color-text-secondary);
    transition: all var(--transition-fast);
    cursor: default;
  }

  .tech-tag:hover {
    background: rgba(0,212,255,0.12);
    border-color: var(--color-accent-cyan);
    color: var(--color-accent-cyan);
  }

  @media (max-width: 900px) {
    .why-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 600px) {
    .why-grid { grid-template-columns: 1fr; }
  }
</style>
