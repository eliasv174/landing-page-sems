---
// src/components/CTA.astro
---

<section id="contacto" class="section cta-section" aria-labelledby="contacto-title">
  <!-- Background -->
  <div class="cta-bg" aria-hidden="true">
    <div class="cta-orb"></div>
  </div>

  <div class="container">
    <div class="cta-wrapper">
      <div class="cta-content reveal">
        <span class="section-eyebrow">¿Listo para el siguiente paso?</span>
        <h2 class="section-title" id="contacto-title" style="text-align:left; margin-top: 0.5rem;">
          Hablemos de tu <span class="accent">proyecto</span>
        </h2>
        <div class="divider" style="margin: var(--space-4) 0;"></div>
        <p class="cta-desc">
          Cuéntanos tu reto tecnológico. Ofrecemos una <strong>consulta inicial gratuita</strong>
          donde evaluamos tu situación y te presentamos opciones concretas sin compromiso.
        </p>

        <!-- Contact Options -->
        <div class="contact-options reveal delay-1">
          <a
            href="https://wa.me/50254890516?text=Hola%20SEMS%2C%20me%20gustar%C3%ADa%20una%20consulta%20sobre%20transformaci%C3%B3n%20digital"
            class="btn btn-whatsapp"
            id="cta-whatsapp-btn"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Contactar por WhatsApp"
          >
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.886 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            WhatsApp
          </a>

          <a
            href="mailto:contacto@sems-gt.cloud"
            class="btn btn-secondary"
            id="cta-email-btn"
            aria-label="Enviar correo a SEMS"
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
              <polyline points="22,6 12,13 2,6"/>
            </svg>
            Envíanos un email
          </a>
        </div>

        <!-- Features list -->
        <ul class="cta-features reveal delay-2" aria-label="Lo que incluye la consulta">
          {[
            'Diagnóstico inicial gratuito',
            'Sin compromiso de contratación',
            'Presupuesto detallado y transparente',
          ].map(feat => (
            <li class="cta-feature">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#00D4FF" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <polyline points="20 6 9 17 4 12"/>
              </svg>
              {feat}
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact Info Panel -->
      <div class="cta-panel reveal delay-2">
        <h3 class="panel-title">Información de contacto</h3>

        <div class="contact-info">
          <div class="contact-item">
            <div class="contact-icon" aria-hidden="true">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 2.18h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 9.91a16 16 0 0 0 6.07 6.07l1.79-1.79a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
              </svg>
            </div>
            <div>
              <span class="contact-label">WhatsApp</span>
              <a href="https://wa.me/50254890516" class="contact-value" target="_blank" rel="noopener noreferrer">+502 54890516</a>
            </div>
          </div>

          <div class="contact-item">
            <div class="contact-icon" aria-hidden="true">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                <polyline points="22,6 12,13 2,6"/>
              </svg>
            </div>
            <div>
              <span class="contact-label">Email</span>
              <a href="mailto:contacto@sems-gt.cloud" class="contact-value">contacto@sems-gt.cloud</a>
            </div>
          </div>

          <div class="contact-item">
            <div class="contact-icon" aria-hidden="true">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
                <circle cx="12" cy="10" r="3"/>
              </svg>
            </div>
            <div>
              <span class="contact-label">Ubicación</span>
              <span class="contact-value">Guatemala, Guatemala</span>
            </div>
          </div>

          <div class="contact-item">
            <div class="contact-icon" aria-hidden="true">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"/>
                <polyline points="12 6 12 12 16 14"/>
              </svg>
            </div>
            <div>
              <span class="contact-label">Horario</span>
              <span class="contact-value">Lun – Vie 8:00 – 18:00 GTM</span>
            </div>
          </div>
        </div>

        <!-- Availability indicator -->
        <div class="availability">
          <div class="availability-dot" aria-hidden="true"></div>
          <span>Disponibles para nuevos proyectos</span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .cta-section {
    position: relative;
    overflow: hidden;
    background: linear-gradient(135deg, var(--color-bg-secondary) 0%, var(--color-bg-primary) 100%);
  }

  .cta-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .cta-orb {
    position: absolute;
    width: 600px;
    height: 600px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(124,58,237,0.1) 0%, transparent 70%);
    top: 50%;
    right: -200px;
    transform: translateY(-50%);
    filter: blur(60px);
  }

  .cta-wrapper {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: var(--space-16);
    align-items: flex-start;
  }

  /* Content */
  .cta-desc {
    font-size: var(--text-base);
    line-height: 1.75;
    color: var(--color-text-secondary);
    margin-bottom: var(--space-6);
  }

  .cta-desc strong { color: var(--color-accent-cyan); font-weight: 600; }

  .contact-options {
    display: flex;
    gap: var(--space-4);
    flex-wrap: wrap;
    margin-bottom: var(--space-6);
  }

  /* Features */
  .cta-features {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .cta-feature {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
  }

  /* Panel */
  .cta-panel {
    background: var(--gradient-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    padding: var(--space-8);
    position: sticky;
    top: 100px;
  }

  .panel-title {
    font-size: var(--text-lg);
    font-weight: 700;
    color: var(--color-text-primary);
    margin-bottom: var(--space-6);
    padding-bottom: var(--space-4);
    border-bottom: 1px solid var(--color-border);
  }

  .contact-info {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
    margin-bottom: var(--space-6);
  }

  .contact-item {
    display: flex;
    align-items: flex-start;
    gap: var(--space-4);
  }

  .contact-icon {
    width: 38px;
    height: 38px;
    border-radius: var(--radius-md);
    background: rgba(0,212,255,0.08);
    border: 1px solid var(--color-border);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-accent-cyan);
    flex-shrink: 0;
  }

  .contact-label {
    display: block;
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 600;
    margin-bottom: 2px;
  }

  .contact-value {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-text-primary);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  a.contact-value:hover { color: var(--color-accent-cyan); }

  /* Availability */
  .availability {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-3) var(--space-4);
    background: rgba(0,229,160,0.06);
    border: 1px solid rgba(0,229,160,0.2);
    border-radius: var(--radius-full);
    font-size: var(--text-sm);
    color: var(--color-accent-green);
    font-weight: 600;
  }

  .availability-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--color-accent-green);
    animation: pulse-glow 2s ease infinite;
    flex-shrink: 0;
  }

  @media (max-width: 900px) {
    .cta-wrapper { grid-template-columns: 1fr; gap: var(--space-10); }
    .cta-panel { position: static; }
  }

  @media (max-width: 480px) {
    .contact-options { flex-direction: column; }
    .contact-options .btn { width: 100%; justify-content: center; }
  }
</style>
